# ─── App URL (producción) ────────────────────────────────────────────────────
# URL pública de la app. En Vercel se puede usar la variable automática:
# NEXT_PUBLIC_APP_URL=$VERCEL_URL (o pon la URL exacta de tu dominio)
NEXT_PUBLIC_APP_URL=https://tu-app.vercel.app

# ─── Supabase (Backend real - Fase 3) ───────────────────────────────────────
# Crea tu proyecto en https://supabase.com (gratis hasta 50K usuarios)
# Obtén estas claves en: Proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# Clave privada solo en servidor (no exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# ─── PostHog Analytics (Fase 3) ─────────────────────────────────────────────
# Crea cuenta en https://posthog.com (gratis: 1M eventos/mes)
# Obtén la clave en: Proyecto → Settings → Project API keys
NEXT_PUBLIC_POSTHOG_KEY=phc_tu-clave-de-posthog
# Para self-hosted: NEXT_PUBLIC_POSTHOG_HOST=https://tu-instancia-posthog.com
# Para cloud EU: NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com (default)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ─── Web Push Notifications (Fase 3) ────────────────────────────────────────
# Genera tus claves VAPID con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=tu-vapid-public-key
VAPID_PRIVATE_KEY=tu-vapid-private-key
VAPID_SUBJECT=mailto:tu-email@dominio.com
